# =============================================================================
# OmegaHack — environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- Supabase (remote) ---
# Public — safe to expose to browser via Next.js NEXT_PUBLIC_ prefix.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres direct connections (role-scoped) ---
# Format: postgresql://postgres.<ref>:<pwd>@<pooler-host>:6543/postgres?options=-c+role%3D<role>
# The `options=-c+role=<role>` suffix auto-runs SET ROLE on connect so queries
# are scoped to app_operational / app_qa_reader regardless of login user.
DATABASE_URL_OPERATIONAL=
DATABASE_URL_QA_READER=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Observability ---
SENTRY_DSN=
GRAFANA_CLOUD_INSTANCE_ID=

# --- n8n ---
N8N_WEBHOOK_BASE_URL=

# --- Supabase CLI (for local scripts, not apps) ---
SUPABASE_DB_PASSWORD=
